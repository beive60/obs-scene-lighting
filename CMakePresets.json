{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "template",
      "hidden": true,
      "cacheVariables": {
        "OBS_BOOTSTRAP_DEPS": true,
        "ENABLE_CLANG_TIDY": true,
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build_x64/install"
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "description": "Bootstrap OBS dependencies and build the plugin for Windows x64",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 17 2022",
      "architecture": "x64,version=10.0.22621",
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64",
      "displayName": "Windows x64",
      "description": "Build the Windows x64 plugin in RelWithDebInfo",
      "configuration": "RelWithDebInfo"
    }
  ]
}
